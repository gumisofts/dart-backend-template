# See https://www.dartlang.org/guides/libraries/private-files

# Files and directories created by pub
.dart_tool/
.packages
build/
pubspec.lock

# Dartdoc
doc/api/

# dotenv — never commit real secrets
.env
.env.local

# build_runner generated files
*.g.dart
*.gisila.g.dart
*.gisila.g.part
*.gisila_doc.g.part
*.gisila.up.sql
*.gisila.down.sql

# GisilaORM migration snapshots
.gisila/

# Compiled native executable
/build/

# Avoid committing generated Javascript files:
*.dart.js
*.info.json
*.js
*.js_
*.js.deps
*.js.map

.flutter-plugins
.flutter-plugins-dependencies
